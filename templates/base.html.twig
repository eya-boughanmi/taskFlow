<!DOCTYPE html>
<html lang="fr" data-turbo-prefetch="true">
<head>
    {% include 'partials/_head_dashboard.html.twig' %}
    <title>{% block title %}TaskFlow{% endblock %}</title>
    {% block stylesheets %}{% endblock %}
</head>
<body class="tf-page-gradient tf-turbo-app">
{{ importmap('app') }}
<div>
    <div id="tf-persist-sidebar" data-turbo-permanent>
        {% include 'partials/_sidebar.html.twig' %}
    </div>

    <div id="content" class="position-relative h-100">
        {% include 'partials/_topbar.html.twig' %}

        <div class="custom-container py-lg-4 py-3 px-3 px-lg-6" id="tf-main-scroll">
            {% include 'partials/_flash.html.twig' %}
            {% block page_header %}{% endblock %}
            {% block body %}{% endblock %}
        </div>

        <footer class="text-center text-secondary small py-6 mt-4 border-top border-dashed">
            TaskFlow — gestion de projets · © {{ 'now'|date('Y') }}
        </footer>
    </div>
</div>

<div class="modal fade" id="tfImagePreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content tf-glass border-0 overflow-hidden">
            <div class="modal-header border-0 py-3">
                <h5 class="modal-title small text-secondary text-uppercase">Aperçu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body p-0 bg-dark bg-opacity-10 text-center">
                <img src="" alt="" id="tf-preview-img" class="img-fluid w-100" style="max-height:85vh;object-fit:contain;">
            </div>
        </div>
    </div>
</div>

{% include 'partials/_scripts_dashboard.html.twig' %}
{% block javascripts %}{% endblock %}
</body>
</html>

{% extends 'base.html.twig' %}

{% block title %}{{ projet is not null and projet.id ? 'Modifier le projet' : 'Nouveau projet' }} · TaskFlow{% endblock %}

{% block page_header %}
    <div class="mb-6 tf-reveal">
        <p class="text-secondary small text-uppercase fw-semibold mb-1">Formulaire</p>
        <h1 class="h2 mb-0">{{ projet is not null and projet.id ? 'Modifier le projet' : 'Nouveau projet' }}</h1>
    </div>
{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-xl-8">
            <div class="card card-lg border-0 shadow-sm tf-glass tf-reveal">
                <div class="card-body p-lg-6">
                    {% if projet is not null and projet.imageName %}
                        <div class="mb-4 p-4 rounded-3 bg-body-secondary bg-opacity-50 border border-dashed">
                            <p class="small text-secondary mb-2">Image actuelle</p>
                            {% set ext = projet.imageName|lower|split('.')|last %}
                            {% set u = asset('uploads/projets/' ~ projet.imageName) %}
                            {% if ext in ['jpg','jpeg','png','gif','webp','svg'] %}
                                <a href="{{ u }}" data-tf-image-preview class="d-inline-block rounded-3 overflow-hidden border">
                                    <img src="{{ u }}" alt="" class="img-fluid rounded-3" style="max-height:200px;object-fit:cover;">
                                </a>
                            {% else %}
                                <a href="{{ u }}" target="_blank" class="btn btn-white border btn-sm"><i class="ti ti-file-download me-1"></i> Fichier actuel</a>
                            {% endif %}
                            <p class="text-secondary small mt-2 mb-0">Choisissez un nouveau fichier ci-dessous pour remplacer.</p>
                        </div>
                    {% endif %}

                    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
                        {{ form_row(form.nom) }}
                        {{ form_row(form.description) }}
                        {{ form_row(form.dateLimite) }}
                        {{ form_row(form.statut) }}
                        <div class="mb-3">
                            {{ form_label(form.image) }}
                            {{ form_widget(form.image, {'attr': {'class': 'form-control'}}) }}
                            {{ form_help(form.image) }}
                            {{ form_errors(form.image) }}
                        </div>
                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <button type="submit" class="btn btn-gradient-primary btn-lg shadow-sm">
                                <i class="ti ti-device-floppy me-1"></i> Enregistrer
                            </button>
                            <a href="{{ projet ? path('projet_show', {id: projet.id}) : path('projet_index') }}" class="btn btn-white btn-lg border">Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ projet.nom }}{% endblock %}

{% block body %}
<div class="container mt-4">

    <h1>{{ projet.nom }}</h1>

    {% if projet.imageName %}
        <img src="{{ asset('uploads/projets/' ~ projet.imageName) }}" class="img-fluid mb-3" style="max-height:300px;object-fit:cover;">
    {% endif %}

    <p>{{ projet.description }}</p>

    {# Barre de progression #}
    {% set total = projet.taches|length %}
    {% set done = projet.taches|filter(t => t.statut == 'terminee')|length %}
    {% set percent = total > 0 ? (done / total * 100)|round : 0 %}

    <div class="progress mb-3">
        <div class="progress-bar bg-success" style="width: {{ percent }}%">
            {{ percent }}%
        </div>
    </div>

    {# Statistiques du service #}
    <div class="mb-4">
        <h5>Statistiques</h5>
        <p><strong>Progression :</strong> {{ progress }}%</p>
        <p><strong>Tâches :</strong></p>
        <ul>
            <li>À faire : {{ counts.a_faire }}</li>
            <li>En cours : {{ counts.en_cours }}</li>
            <li>Terminées : {{ counts.terminee }}</li>
        </ul>
        {% if overdue %}
            <p class="text-danger fw-bold">⚠️ Projet en retard !</p>
        {% else %}
            <p class="text-success">Jours restants : {{ remaining }}</p>
        {% endif %}
    </div>

    {# Bouton modifier projet #}
    {% if app.user == projet.createur or is_granted('ROLE_ADMIN') %}
        <a href="{{ path('projet_edit', {id: projet.id}) }}" class="btn btn-warning mb-3">
            ✏️ Modifier le projet
        </a>
    {% endif %}

    <h3>Tâches</h3>
    {% if is_granted('ROLE_USER') %}
        <a href="{{ path('tache_new', {id: projet.id}) }}" class="btn btn-primary mb-3">
            ➕ Ajouter une tâche
        </a>
    {% endif %}

    <hr>

    {# Derniers projets consultés #}
    {% if recentProjects|length > 0 %}
    <div class="mb-4">
        <h4>📋 Derniers projets consultés</h4>
        <ul class="list-group">
            {% for rp in recentProjects %}
                <li class="list-group-item">
                    <a href="{{ path('projet_show', {id: rp.id}) }}">{{ rp.nom }}</a>
                </li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    <table class="table table-bordered">
        <thead>
        <tr>
            <th>Titre</th>
            <th>Statut</th>
            <th>Priorité</th>
            <th>Étiquettes</th>
            <th>Fichier</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for t in taches %}
        <tr>
            <td>{{ t.titre }}</td>

            <td>
                {% if t.statut == 'a_faire' %}
                    <span class="badge bg-secondary">À faire</span>
                {% elseif t.statut == 'en_cours' %}
                    <span class="badge bg-warning text-dark">En cours</span>
                {% elseif t.statut == 'terminee' %}
                    <span class="badge bg-success">Terminée</span>
                {% endif %}
            </td>

            <td>
                {% if t.priorite == 'basse' %}
                    <span class="badge bg-primary">🔵 Basse</span>
                {% elseif t.priorite == 'moyenne' %}
                    <span class="badge bg-success">🟢 Moyenne</span>
                {% elseif t.priorite == 'haute' %}
                    <span class="badge bg-warning text-dark">🟠 Haute</span>
                {% elseif t.priorite == 'urgente' %}
                    <span class="badge bg-danger">🔴 Urgente</span>
                {% endif %}
            </td>

            <td>
                {% for e in t.etiquettes %}
                    <span class="badge" style="background-color: {{ e.couleur }}">{{ e.nom }}</span>
                {% endfor %}
            </td>

            <td>
                {% if t.pieceJointeName %}
                   <a href="{{ asset('uploads/taches/' ~ t.pieceJointeName) }}" target="_blank" class="btn btn-sm btn-outline-secondary">
    📎 Télécharger
</a>
{% else %}
    -
{% endif %}
</td>

<td>
    <a href="{{ path('tache_edit', {id: t.id}) }}" class="btn btn-sm btn-warning">
        Modifier
    </a>

    <form method="post"
          action="{{ path('tache_delete', {id: t.id}) }}"
          style="display:inline"
          class="delete-tache-form">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ t.id) }}">
        <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
    </form>
</td>
</tr>

{% else %}
<tr>
    <td colspan="6" class="text-center">Aucune tâche pour ce projet.</td>
</tr>
{% endfor %}

</tbody>
</table>
{# PAGINATION TACHES #}
<div class="d-flex justify-content-center mt-3">
    {{ knp_pagination_render(taches) }}
</div>

</div>

{% endblock %}
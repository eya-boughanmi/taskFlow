{% extends 'layout/login.html.twig' %}

{% block title %}Connexion · TaskFlow{% endblock %}

{% block body %}
<section class="tf-login-shell min-vh-100">
    <div class="row g-0 min-vh-100 flex-column flex-lg-row align-items-stretch">
        {# Colonne gauche : illustration + message (visible aussi sur mobile, version compacte) #}
        <div class="col-lg-6 tf-login-hero-col position-relative overflow-hidden">
            <div class="tf-login-hero-bg position-absolute top-0 start-0 w-100 h-100"></div>
            <div class="position-relative z-1 d-flex flex-column p-4 p-lg-6 p-xl-8 text-white h-100 tf-login-hero-inner tf-login-hero-inner--centered">
                <div class="tf-login-hero-head flex-shrink-0">
                    <a href="{{ path('app_dashboard') }}" class="d-inline-flex align-items-center gap-2 text-white text-decoration-none mb-3 mb-lg-4 tf-login-fade" data-turbo="false">
                        <img src="{{ asset('dasher/assets/images/brand/logo/logo-icon.svg') }}" alt="" width="44" height="44" class="rounded-3 shadow"/>
                        <span class="fw-bold fs-3">TaskFlow</span>
                    </a>
                    <h2 class="h1 fw-bold mb-2 mb-lg-3 tf-login-fade tf-login-fade-delay-1">Pilotez vos projets.</h2>
                    <p class="text-white-50 mb-0 tf-login-fade tf-login-fade-delay-2 tf-login-lead">
                        Tableaux de bord, priorités et livrables — une interface pensée comme une application SaaS.
                    </p>
                </div>

                {# Illustration existante : zone hero centrée (milieu de la colonne / viewport visuel) #}
                <div class="tf-login-hero-illus flex-grow-1 d-flex align-items-center justify-content-center w-100 py-4 py-lg-5">
                    <div class="tf-login-illus-wrap tf-login-illus-wrap--hero tf-login-fade tf-login-fade-delay-3 w-100">
                        <div class="tf-login-illus-scene mx-auto">
                            {% include 'partials/_illustration_saas_tasks.svg.twig' %}
                        </div>
                    </div>
                </div>

                <p class="small text-white-50 mb-0 tf-login-fade tf-login-fade-delay-4 flex-shrink-0 d-none d-lg-block">© {{ 'now'|date('Y') }} TaskFlow</p>
            </div>
        </div>

        {# Colonne droite : formulaire #}
        <div class="col-lg-6 d-flex align-items-center justify-content-center p-4 p-xl-6 bg-body tf-login-form-col">
            <div class="w-100 tf-login-form-max">
                <div class="text-center text-lg-start mb-4 d-lg-none">
                    <p class="small text-secondary mb-0">© {{ 'now'|date('Y') }} TaskFlow</p>
                </div>

                {% include 'partials/_flash.html.twig' %}

                <div class="text-center text-lg-start mb-4">
                    <h1 class="h2 fw-bold mb-2">Connexion</h1>
                    <p class="text-secondary mb-0">
                        Pas encore de compte ?
                        <a href="{{ path('app_register') }}" class="fw-semibold text-decoration-none" data-turbo="false">S'inscrire</a>
                    </p>
                </div>

                <div class="card border-0 shadow-lg tf-glass tf-login-card tf-login-rise">
                    <div class="card-body p-4 p-md-5">

                        {# ── Bloc d'erreur d'authentification (mauvais identifiants, compte inexistant…) #}
                        {% if error %}
                            <div class="alert alert-danger border-0 shadow-sm mb-4 d-flex align-items-start gap-2" role="alert">
                                <i class="ti ti-alert-circle fs-5 mt-1 flex-shrink-0"></i>
                                <div>
                                    {% set msg = error.messageKey %}
                                    {% if msg == 'Invalid credentials.' %}
                                        <strong>Identifiants incorrects.</strong><br>
                                        Vérifiez votre adresse e-mail et votre mot de passe, puis réessayez.
                                    {% elseif msg == 'Username could not be found.' or 'user.not_found' in msg %}
                                        <strong>Aucun compte trouvé.</strong><br>
                                        Cette adresse e-mail n'est associée à aucun compte. <a href="{{ path('app_register') }}" class="alert-link">Créer un compte</a>.
                                    {% elseif 'Too many failed login attempts' in msg %}
                                        <strong>Trop de tentatives.</strong><br>
                                        Votre accès est temporairement bloqué. Veuillez patienter avant de réessayer.
                                    {% else %}
                                        {{ error.messageKey|trans(error.messageData, 'security') }}
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}

                        {% if app.user %}
                            <div class="alert alert-info border-0 mb-4">
                                Connecté en tant que <strong>{{ app.user.userIdentifier }}</strong> —
                                <a href="{{ logout_path() }}" class="fw-semibold" data-turbo="false">Se déconnecter</a>
                            </div>
                        {% endif %}

                        {#
                            IMPORTANT : l'action du formulaire DOIT pointer sur /login
                            pour que le firewall Symfony intercepte la requête POST.
                            Sans cet attribut action, Symfony ne peut pas authentifier l'utilisateur.
                        #}
                        <form method="post" action="{{ path('app_login') }}" class="needs-validation" novalidate data-turbo="false">
                            <div class="mb-3">
                                <label for="inputEmail" class="form-label">Email <span class="text-danger">*</span></label>
                                <input type="email"
                                       value="{{ last_username }}"
                                       name="email"
                                       id="inputEmail"
                                       class="form-control form-control-lg{% if error %} is-invalid{% endif %}"
                                       autocomplete="email"
                                       required
                                       autofocus>
                                <div class="invalid-feedback">Adresse e-mail invalide.</div>
                            </div>

                            <div class="mb-3">
                                <label for="inputPassword" class="form-label">Mot de passe <span class="text-danger">*</span></label>
                                <div class="password-field position-relative">
                                    <input type="password"
                                           name="password"
                                           id="inputPassword"
                                           class="form-control form-control-lg fakePassword{% if error %} is-invalid{% endif %}"
                                           autocomplete="current-password"
                                           required>
                                    <span class="position-absolute top-50 end-0 translate-middle-y pe-3" style="cursor:pointer;">
                                        <i class="ti ti-eye-off passwordToggler"></i>
                                    </span>
                                    <div class="invalid-feedback">Mot de passe requis.</div>
                                </div>
                            </div>

                            {# Token CSRF obligatoire — Symfony le vérifie dans le CsrfTokenBadge de l'authenticator #}
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                            <div class="mb-4 d-flex align-items-center justify-content-between flex-wrap gap-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="_remember_me" id="rememberMeCheckbox">
                                    <label class="form-check-label" for="rememberMeCheckbox">Se souvenir de moi</label>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button class="btn btn-gradient-primary btn-lg text-white" type="submit">
                                    <i class="ti ti-login me-1"></i> Se connecter
                                </button>
                                <a href="{{ path('app_dashboard') }}" class="btn btn-white border btn-lg" data-turbo="false">Tableau de bord</a>
                            </div>
                        </form>
                    </div>
                </div>

                <p class="text-center text-secondary small mt-4 mb-0">
                    <a href="{{ path('projet_index') }}" class="text-decoration-none" data-turbo="false">Voir les projets (invité)</a>
                </p>
            </div>
        </div>
    </div>
</section>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('dasher/assets/js/vendors/password.js') }}"></script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Étiquettes{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Liste des étiquettes</h1>
    <a href="{{ path('etiquette_new') }}" class="btn btn-primary mb-3">Ajouter</a>

    <table class="table">
        <tr>
            <th>Nom</th>
            <th>Couleur</th>
            <th>Actions</th>
        </tr>
        {% for e in etiquettes %}
        <tr>
            <td>{{ e.nom }}</td>
            <td>
                <span class="badge" style="background-color: {{ e.couleur }}">{{ e.couleur }}</span>
            </td>
            <td>
                <form method="post" action="{{ path('etiquette_delete', {id: e.id}) }}" onsubmit="return confirm('Supprimer ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ e.id) }}">
                    <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="3">Aucune étiquette.</td></tr>
        {% endfor %}
    </table>
</div>
{% endblock %}
